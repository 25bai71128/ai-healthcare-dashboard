# App security
FLASK_SECRET_KEY=change-me
SESSION_COOKIE_SECURE=false
AUTH_REQUIRED=false

# Optional API protection
API_KEY=

# Optional role users
ADMIN_USER=admin
ADMIN_PASSWORD=admin123
ANALYST_USER=analyst
ANALYST_PASSWORD=analyst123

# Optional PostgreSQL (fallback is SQLite if unset)
DATABASE_URL=

# Optional report generation (disabled by default on Vercel)
ENABLE_REPORTS=false

# Optional runtime paths (useful for serverless environments)
APP_RUNTIME_DIR=/tmp/ai_healthcare_project
TRAINED_MODELS_DIR=
METADATA_DIR=
ACTIVE_VERSIONS_FILE=

# Optional external artifact sync (recommended for Vercel)
MODEL_ARCHIVE_URL=
METADATA_ARCHIVE_URL=
DATA_ARCHIVE_URL=
DATASET_URL=
MODEL_FILE_URL=
MODEL_FILE_NAME=
METADATA_FILE_URL=
METADATA_FILE_NAME=
ACTIVE_VERSIONS_URL=
FORCE_EXTERNAL_ASSET_SYNC=false
SKIP_EXTERNAL_ASSET_SYNC=false

# -------------------------------------------
# Next.js healthcare dashboard configuration
# -------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-long-random-secret

# Prisma PostgreSQL connection (Supabase compatible)
# Example:
# DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres?sslmode=require

# 32-byte base64 key for AES-256-GCM field encryption.
# Generate with: openssl rand -base64 32
FIELD_ENCRYPTION_KEY=

# Optional initial demo user (seed script)
SEED_USER_EMAIL=clinician@carepulse.dev
SEED_USER_PASSWORD=ChangeThisNow123!
SEED_PATIENT_NAME=Jordan Smith
